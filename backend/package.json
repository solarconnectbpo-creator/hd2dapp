{
  "name": "hd2d-backend",
  "version": "1.0.0",
  "description": "HD2D Hardcore Door to Door Closers - Backend API",
  "main": "src/index.ts",
  "type": "module",
  "scripts": {
    "dev": "npx wrangler dev --local --port 8787",
    "d1:migrate:local": "npx wrangler d1 execute d2d --local --file=./migrations/0001_users.sql",
    "d1:migrate:remote": "node scripts/wrangler-run.mjs d1 execute d2d --remote --file=./migrations/0001_users.sql",
    "d1:migrate:local:access": "npx wrangler d1 execute d2d --local --file=./migrations/0006_user_access_billing.sql",
    "d1:migrate:remote:access": "node scripts/wrangler-run.mjs d1 execute d2d --remote --file=./migrations/0006_user_access_billing.sql",
    "d1:migrate:local:sms": "npx wrangler d1 execute d2d --local --file=./migrations/0007_sms_automation.sql",
    "d1:migrate:remote:sms": "node scripts/wrangler-run.mjs d1 execute d2d --remote --file=./migrations/0007_sms_automation.sql",
    "d1:migrate:local:sms_v2": "npx wrangler d1 execute d2d --local --file=./migrations/0008_sms_automation_v2.sql",
    "d1:migrate:remote:sms_v2": "node scripts/wrangler-run.mjs d1 execute d2d --remote --file=./migrations/0008_sms_automation_v2.sql",
    "d1:migrate:local:marketplace": "npx wrangler d1 execute d2d --local --file=./migrations/0009_marketplace_appointments.sql",
    "d1:migrate:remote:marketplace": "node scripts/wrangler-run.mjs d1 execute d2d --remote --file=./migrations/0009_marketplace_appointments.sql",
    "d1:migrate:local:org_workspace": "npx wrangler d1 execute d2d --local --file=./migrations/0010_org_workspace.sql",
    "d1:migrate:remote:org_workspace": "node scripts/wrangler-run.mjs d1 execute d2d --remote --file=./migrations/0010_org_workspace.sql",
    "d1:migrate:local:perf": "npx wrangler d1 execute d2d --local --file=./migrations/0011_performance_indices.sql",
    "d1:migrate:remote:perf": "node scripts/wrangler-run.mjs d1 execute d2d --remote --file=./migrations/0011_performance_indices.sql",
    "deploy": "node scripts/wrangler-run.mjs deploy --env=\"\" --keep-vars true",
    "deploy:all": "npm run deploy && npm --prefix ../roofing-estimator-vite run pages:deploy",
    "build": "npx wrangler build",
    "smoke:health": "node scripts/health-smoke.mjs",
    "verify:worker": "node scripts/check-worker-deploy.mjs",
    "preflight:eagleview-embedded": "node scripts/eagleview-embedded-preflight.mjs",
    "smoke:eagleview-token": "node scripts/eagleview-token-smoke.mjs",
    "report-server": "node server.js",
    "secret:openai:prod": "node scripts/wrangler-secret-put-from-env.mjs OPENAI_API_KEY OPENAI_API_KEY -- --config wrangler.toml --env production",
    "secret:eagleview:prod": "npx wrangler secret put EAGLEVIEW_CLIENT_ID --config wrangler.toml --env production && npx wrangler secret put EAGLEVIEW_CLIENT_SECRET --config wrangler.toml --env production",
    "secret:dealmachine": "node scripts/wrangler-secret-put-from-env.mjs DEALMACHINE_API_KEY DEALMACHINE_API_KEY",
    "secret:dealmachine:prod": "node scripts/wrangler-secret-put-from-env.mjs DEALMACHINE_API_KEY DEALMACHINE_API_KEY -- --config wrangler.toml --env production",
    "secret:auth-admin": "node scripts/set-auth-admin-secrets.mjs",
    "deploy:prod": "node scripts/wrangler-run.mjs deploy --config wrangler.toml --env production --keep-vars true",
    "dev:full:vision": "npm run dev:full:vision --prefix ../roofing-estimator-vite",
    "vision:dev": "npm run dev --prefix ml-vision-service",
    "vision:download-sam": "npm run download-sam --prefix ml-vision-service",
    "deploy:vision:fly": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/fly-deploy-vision.ps1",
    "deploy:vision:fly:worker": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/fly-deploy-vision-with-worker.ps1",
    "worker:set-roof-vision": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/set-roof-vision-worker-secrets.ps1"
  },
  "dependencies": {
    "@sentry/cloudflare": "^9.47.1",
    "cors": "^2.8.5",
    "express": "^5.1.0",
    "node-fetch": "^3.3.2",
    "openai": "^4.28.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20240620.0",
    "typescript": "^5.3.0",
    "wrangler": "^4.80.0"
  }
}
