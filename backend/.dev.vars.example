# Copy to `.dev.vars` for local `wrangler dev`, or run from roofing app:
#   cd ../roofing-estimator-vite && npm run sync:eagleview-dev
#
# Token URL + API base default from wrangler.toml [vars]; only secrets required here:

# EAGLEVIEW_CLIENT_ID=
# EAGLEVIEW_CLIENT_SECRET=
# EAGLEVIEW_OAUTH_CLIENT_ID=
# EAGLEVIEW_SCOPE=
# Embedded Explorer credentials (recommended to set explicitly; many API Center creds will be rejected for embedded auth):
# EAGLEVIEW_EMBEDDED_CLIENT_ID=
# EAGLEVIEW_EMBEDDED_CLIENT_SECRET=
# EAGLEVIEW_EMBEDDED_TOKEN_URL=https://api.eagleview.com/auth-service/v1/token
# EAGLEVIEW_EMBEDDED_SCOPE=

# Auth: D1 users (sign-up + admin-created) always work. Env-based demo slots (AUTH_*) are OFF unless you opt in:
# AUTH_ENV_LOGIN_ENABLED=true
# Optional overrides when AUTH_ENV_LOGIN_ENABLED=true (defaults below match former demo accounts):
# AUTH_ADMIN_EMAIL=admin@hardcoredoortodoorclosers.com
# AUTH_ADMIN_PASSWORD=AdminTest123!
# AUTH_ADMIN_NAME=Admin
# AUTH_COMPANY_EMAIL=test.company@hardcoredoortodoorclosers.com
# AUTH_COMPANY_PASSWORD=TestCompany123!
# AUTH_REP_EMAIL=test.rep@hardcoredoortodoorclosers.com
# AUTH_REP_PASSWORD=TestRep123!
# SESSION_SECRET=change-me
# Optional: GET /api/auth/me returns 401 if user was removed from D1 (503 if D1 errors). Can force re-auth after deletes:
# AUTH_REQUIRE_DB_USER_FOR_ME=true

# ML vision — Worker proxies /api/ai/roof-vision + /api/ai/roof-segment → ml-vision-service (see backend/ml-vision-service/README.md).
# Same-origin app flow: Vite `/intel-proxy` → Worker → ROOF_VISION_SERVICE_URL (local default: http://127.0.0.1:18090).
# One terminal (from roofing-estimator-vite): npm run dev:full:vision  (Worker + vision + Vite).
# Copy the same secret string into ml-vision-service/.env as SERVICE_SECRET=...
# ROOF_VISION_SERVICE_URL=http://127.0.0.1:18090
# ROOF_VISION_SERVICE_SECRET=hd2d-local-dev-roof-vision-secret
# Windows: if the port is busy (10048), stop the other process or set VISION_DEV_PORT and match ROOF_VISION_SERVICE_URL.

# --- DealMachine (Canvassing owner enrichment + Property records) ---
# Recommended for full Canvassing: uncomment DEALMACHINE_API_KEY (SPA defaults to DealMachine relaxed fallback in Contacts settings).
# Required for POST /api/dealmachine/property. Get key: DealMachine app → Application Settings → API.
# Never put this in roofing-estimator-vite — only Worker secrets or this file for local wrangler dev.
# DEALMACHINE_API_KEY=
# Optional (defaults match dealmachineProxy.ts — only if DealMachine docs differ for your account):
# DEALMACHINE_API_BASE=https://public-api.dealmachine.com
# DEALMACHINE_PROPERTY_PATH=/v1/properties/search
# DEALMACHINE_AUTH_MODE=client_key

# ArcGIS parcel layer (Canvassing — GeoJSON overlay + query-at-point). Default: St. Louis County assessor parcels (public).
# Same value is in wrangler.toml [vars]; uncomment to override locally or use another county FeatureServer …/FeatureServer/N URL.
# If the var is missing/blank, the Worker uses the same STL default (see arcgisParcelEnv.ts).
# ARCGIS_FEATURE_LAYER_URL=https://services6.arcgis.com/evmyRZRrsopdeog7/arcgis/rest/services/AssessorsParcels/FeatureServer/0
# ARCGIS_FEATURE_LAYER_URL=__DISABLE_ARCGIS_PARCEL__   # advanced: turn off parcel layer entirely
# Optional: override City of St. Louis parcel MapServer layer (default: maps8 assessor Parcels/11). Independent city is not in STL County parcels.
# ARCGIS_STL_CITY_PARCEL_LAYER_URL=https://maps8.stlouis-mo.gov/arcgis/rest/services/ASSESSOR/Assessor_Public_Parcels/MapServer/11
# ARCGIS_STL_CITY_PARCEL_LAYER_URL=__DISABLE_STL_CITY_PARCEL__   # skip city merge / point fallback
# ARCGIS_API_TOKEN=   # only if your layer requires a token
# Optional: append county parcel layers (JSON array). Each entry: id, layerUrl (…/FeatureServer/N or …/MapServer/N), west, south, east, north (WGS84).
# ARCGIS_EXTRA_PARCEL_FALLBACKS_JSON=[{"id":"sample_county","layerUrl":"https://example.org/arcgis/rest/services/Parcels/FeatureServer/0","west":-91,"south":40,"east":-90.5,"north":40.5}]

# --- Lead marketplace (Stripe Checkout via POST /api/leads/checkout-session) ---
# STRIPE_SECRET_KEY=sk_test_...
# Comma-separated Price IDs that match VITE_LEAD_PACKAGES_JSON stripePriceId values:
# LEADS_STRIPE_PRICE_IDS=price_abc,price_def
# Public site origin (no trailing slash) for Stripe redirect after payment:
# APP_PUBLIC_ORIGIN=http://127.0.0.1:5173
# Production example: APP_PUBLIC_ORIGIN=https://hardcoredoortodoorclosers.com

# --- Meta (Facebook) — scheduled Page posts + optional draft ad campaigns (see src/api/metaMarketing.ts) ---
# Create a Meta app → Facebook Login → add Valid OAuth Redirect URI: {APP_PUBLIC_ORIGIN}/api/meta/oauth/callback
# META_APP_ID=
# META_APP_SECRET=
# Optional: PAUSED draft campaigns via Marketing API (user token needs ads_management on this ad account):
# META_DEFAULT_AD_ACCOUNT_ID=123456789

# --- GoHighLevel (POST /api/ghl/submit-lead from roofing estimator chat) ---
# Private Integration token from GHL Settings → Private Integrations; Location id from sub-account URL or API.
# GHL_PRIVATE_INTEGRATION_TOKEN=
# GHL_LOCATION_ID=

# Optional ArcGIS MapServer / ImageServer cached tiles for Canvassing (slippy XYZ; exposed in GET /api/health, no secrets in URL):
# ARCGIS_MAPSERVER_TILE_URL=https://your-host/arcgis/rest/services/YourMap/MapServer/tile/{z}/{y}/{x}
# ARCGIS_MAPSERVER_TILE_ATTRIBUTION=County GIS
# ARCGIS_MAPSERVER_TILE_OPACITY=0.55
