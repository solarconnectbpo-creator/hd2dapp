HOST=0.0.0.0
PORT=8090

# stub | roboflow | http_json | detectron2
VISION_PROVIDER=stub

# Optional: must match Worker ROOF_VISION_SERVICE_SECRET
SERVICE_SECRET=

# --- Detectron2 (train in repo /roof-detectron, copy model_final.pth) ---
DETECTRON2_WEIGHTS_PATH=
DETECTRON2_SCORE_THRESH=0.5
DETECTRON2_INCLUDE_POLYGONS=false
# ft² per pixel² — ortho/drone GSD or scale bar. Enables segmentation.estimatedRoofAreaSqFt for estimates.
DETECTRON2_SQFT_PER_PX_SQ=0

# --- Roboflow hosted model ---
ROBOFLOW_API_KEY=
# e.g. my-workspace/roof-damage/1  (see Roboflow deploy page)
ROBOFLOW_MODEL_PATH=

# --- Generic managed API (Vertex, Azure Custom Vision, your own FastAPI, etc.) ---
HTTP_JSON_URL=
HTTP_JSON_BEARER=

# --- SAM (Segment Anything) — Auto Trace on map; Worker proxies POST /api/ai/roof-segment ---
# pip install torch torchvision
# pip install git+https://github.com/facebookresearch/segment-anything.git
# Download: https://dl.fbaipublicfiles.com/segment_anything/sam_vit_b_01ec64.pth
SAM_CHECKPOINT_PATH=
SAM_MODEL_TYPE=vit_b
