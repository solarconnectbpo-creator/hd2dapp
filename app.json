{
  "expo": {
    "name": "Hardcore D2D Closers",
    "slug": "DoorToDoorClosers",
    "version": "1.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "DoorToDoorClosers",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "description": "Hardcore Door-to-Door Closers - The ultimate platform for sales reps and companies",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.DoorToDoorClosers.app",
      "buildNumber": "1",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Location centers the property map and lets you select the roof you are standing at."
      }
    },
    "android": {
      "versionCode": 1,
      "adaptiveIcon": {
        "backgroundColor": "#000000",
        "foregroundImage": "./assets/icon.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.DoorToDoorClosers.app",
      "permissions": [
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION"
      ]
    },
    "web": {
      "output": "single",
      "favicon": "./assets/icon.png"
    },
    "plugins": [
      [
        "expo-splash-screen",
        {
          "image": "./assets/icon.png",
          "imageWidth": 250,
          "resizeMode": "contain",
          "backgroundColor": "#000000"
        }
      ],
      "expo-web-browser",
      "expo-asset",
      [
        "expo-build-properties",
        {
          "android": {
            "compileSdkVersion": 33,
            "targetSdkVersion": 33,
            "minSdkVersion": 21
          }
        }
      ]
    ],
    "experiments": {
      "reactCompiler": false
    }
  }
}
