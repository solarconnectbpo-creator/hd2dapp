{
  "name": "roofing-estimator-vite",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:full": "concurrently -k -n worker,vite -c cyan,magenta \"npm --prefix ../backend run dev\" \"npm run dev\"",
    "dev:full:vision": "concurrently -k -n worker,vision,vite -c cyan,yellow,magenta \"npm --prefix ../backend run dev\" \"npm --prefix ../backend run vision:dev\" \"npm run dev\"",
    "sync:eagleview-dev": "node scripts/sync-eagleview-to-backend-dev-vars.mjs",
    "build": "tsc -b && vite build",
    "pages:create": "npx wrangler pages project create hd2d-closers --production-branch main",
    "pages:add-domain": "node scripts/cloudflare-pages-add-domain.mjs",
    "pages:purge-cache": "node scripts/cloudflare-purge-zone-cache.mjs",
    "pages:check-origin": "node scripts/check-production-origin.mjs",
    "pages:fix-dns": "node scripts/fix-apex-dns-for-pages.mjs",
    "pages:deploy": "npm run build && node scripts/pages-deploy.mjs",
    "deploy:all": "npm --prefix ../backend run deploy && npm run pages:deploy",
    "vercel:deploy": "npx vercel deploy --yes --prod",
    "vercel:preview": "npx vercel deploy --yes",
    "lint": "eslint .",
    "lint:ci": "eslint \"src/lib/**/*.{ts,tsx}\" \"src/components/auth/**/*.{ts,tsx}\" \"src/components/AuthGate.tsx\" \"src/context/AuthContext.tsx\" \"src/pages/{Login,SignUp,AdminLogin,Courses,LeadMarketplace,CallCenter}.tsx\" \"src/layout/Root.tsx\"",
    "preview": "vite preview",
    "test": "vitest run",
    "pricing:import-ai-cheatsheet": "node scripts/import-ai-cheatsheet-pricing.mjs",
    "eagleview:token": "node scripts/eagleview-get-token.mjs",
    "eagleview:post-token": "node scripts/eagleview-post-token-once.mjs",
    "data:mo-parcels": "node scripts/build-mo-open-data-import.mjs",
    "data:mo-parcels:sample": "node scripts/build-mo-open-data-import.mjs --sample",
    "data:mo-commercial-50k": "node scripts/filter-commercial-pm-leads.mjs",
    "data:leads-10k": "node scripts/generate-leads-sample-10000.mjs"
  },
  "dependencies": {
    "@maplibre/maplibre-gl-leaflet": "^0.1.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@tailwindcss/vite": "^4.2.2",
    "@tanstack/react-virtual": "^3.13.23",
    "@turf/turf": "^7.3.4",
    "@types/leaflet": "^1.9.21",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "leaflet": "^1.9.4",
    "leaflet-draw": "^1.0.4",
    "lucide-react": "^1.7.0",
    "maplibre-gl": "^5.21.1",
    "papaparse": "^5.5.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-leaflet": "^5.0.0",
    "react-router": "^7.13.2",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.2",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/leaflet-draw": "^1.0.13",
    "@types/node": "^24.12.0",
    "@types/papaparse": "^5.5.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "adm-zip": "^0.5.16",
    "concurrently": "^9.2.1",
    "csv-parse": "^6.2.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "shapefile": "^0.6.6",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^8.0.1",
    "vitest": "^4.1.0",
    "wrangler": "^4.80.0",
    "xlsx": "^0.18.5"
  }
}
