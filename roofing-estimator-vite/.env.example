# HD2D Cloudflare Worker — intel, auth (/api/auth/*), ArcGIS proxy, etc.
#
# --- Production (Vercel SPA on hardcoredoortodoorclosers.com) ---
# Default: the built app calls `HD2D_WORKER_API_ORIGIN` from src/config/siteOrigin.ts (no env needed).
# Vercel static hosting does not provide /api/* — do NOT point the SPA at same-origin /api (you get 405 / HTML).
#
# Optional override (another Worker or staging):
# VITE_INTEL_API_BASE=https://hd2d-backend.solarconnectbpo.workers.dev
#
# --- Cloudflare Pages + functions/api proxy (same-origin /api/*) ---
# Set at build time:
# VITE_HD2D_SAME_ORIGIN_API=true
#
# Root Directory on Vercel: `roofing-estimator-vite`. `vercel.json` enables client-side routing.

# Estimator chat + “Send to GHL” use the same Worker as intel (VITE_INTEL_API_BASE). Configure GHL on the Worker:
#   GHL_PRIVATE_INTEGRATION_TOKEN, GHL_LOCATION_ID (see backend/.dev.vars.example).
#
# Dev only (`vite`): where the dev server proxies /intel-proxy (default http://127.0.0.1:8787).
# Point at a deployed Worker to use intel without running wrangler locally.
# INTEL_PROXY_TARGET=https://hd2d-backend.YOUR_SUBDOMAIN.workers.dev
#
# One command — Worker + Vite (from this folder): npm run dev:full
# After editing EagleView keys in `.env.local`, push them to the Worker dev file: npm run sync:eagleview-dev

# EagleView TrueDesign — proxied by the HD2D Worker at `/api/eagleview/apicenter/*` (OAuth + Bearer on the server).
# Configure secrets in `backend` (see `backend/wrangler.toml`). Local dev: `backend/.dev.vars` + `wrangler dev`.
# Optional: override proxy URL only if not using the same Worker as intel:
# VITE_EAGLEVIEW_API_BASE=https://custom-host.example.com/api/eagleview/apicenter
# VITE_EAGLEVIEW_ACCESS_TOKEN=  # only with VITE_EAGLEVIEW_API_BASE — direct Bearer (discouraged)

# Google Maps satellite imagery (high-res zoom 21+, $200/mo free credit)
# Get key at: https://console.cloud.google.com → APIs & Services → Credentials → Create API Key
# Enable "Maps JavaScript API" and "Maps Static API"
# VITE_GOOGLE_MAPS_API_KEY=AIza...

# CLI helper (optional): from `roofing-estimator-vite`, `npm run eagleview:token` uses `.env.local` to print a token for debugging — not required when the Worker is configured.

# ArcGIS (Canvassing parcel overlay + point queries) — configure only on the Worker, not in Vite:
#   ARCGIS_FEATURE_LAYER_URL=https://…/FeatureServer/0
#   wrangler secret put ARCGIS_API_TOKEN
#   Optional: ESRI_BUILDING_FOOTPRINT_LAYER_URL (defaults to USGS national building footprints)
# See backend/wrangler.toml and backend/src/api/arcgisProxy.ts.
#
# DealMachine (Canvassing / property records) — only on the Worker: `DEALMACHINE_API_KEY` (see backend/.dev.vars.example).
# The SPA never receives this key; set VITE_INTEL_API_BASE in dev so the app calls wrangler dev.
#
# App defaults: Canvassing owner fallback is ON (DealMachine relaxed) in org settings — see Contacts & settings.
# Legacy browser saves that had fallback "off" are upgraded to ON unless you turn it off there and save.

# /courses page — optional YouTube trailer (video id only, not full URL). Shows "Watch trailer" in the hero when set.
# VITE_COURSES_TRAILER_ID=dQw4w9WgXcQ

# Login CTA "Looking for a roofing company to work for?" — opens in a new tab. If unset, that link goes to `/careers`.
# VITE_CAREERS_URL=https://your-site.com/careers

# /call-center — Gradient/VICIdial realtime report (full URL). Also used for optional iframe (may be blocked by remote headers).
# VITE_CALLCENTER_REALTIME_REPORT_URL=https://ftc2.gradientconnectedai.com/vicidial/realtime_report.php?RR=4&DB=0&groups[]=ALL-ACTIVE&user_group_filter[]=ALL-GROUPS&user_group_filter[]=ALL-GROUPS&ingroup_filter[]=ALL-INGROUPS&adastats=1&SIPmonitorLINK=&IAXmonitorLINK=&usergroup=&UGdisplay=0&UidORname=1&orderby=timeup&SERVdisplay=0&CALLSdisplay=1&PHONEdisplay=0&MONITORdisplay=0&CUSTPHONEdisplay=0&with_inbound=Y&monitor_active=WHISPER&monitor_phone=%20&ALLINGROUPstats=&DROPINGROUPstats=0&NOLEADSalert=&ShowCustPhoneCode=0&CARRIERstats=0&PRESETstats=0&AGENTtimeSTATS=1&AGENTlatency=0&parkSTATS=0&SLAinSTATS=0&INGROUPcolorOVERRIDE=0&droppedOFtotal=0&report_display_type=HTML
# Optional extra links: JSON array of { "label", "url" }.
# VITE_CALLCENTER_EXTRA_REPORTS_JSON=[{"label":"Another report","url":"https://example.com/report"}]

# /leads — Stripe Checkout packages (Price IDs must match Worker allowlist LEADS_STRIPE_PRICE_IDS).
# On the Worker, APP_PUBLIC_ORIGIN must match this app’s live origin (https://your-domain.com, no trailing slash) so Stripe redirects to /leads?checkout=success.
# VITE_LEAD_PACKAGES_JSON=[{"key":"starter","title":"Storm corridor — 25 leads","description":"Sample pack for testing checkout.","stripePriceId":"price_xxx","priceLabel":"$99"}]
