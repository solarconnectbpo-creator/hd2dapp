# HD2D Platform - Environment Variables Template

# ========================================
# FRONTEND ENVIRONMENT (Expo/Web)
# ========================================
EXPO_PUBLIC_API_URL=http://localhost:8787
EXPO_PUBLIC_DOMAIN=localhost
EXPO_PUBLIC_ENVIRONMENT=development
EXPO_PUBLIC_MAPBOX_TOKEN=your-mapbox-token

# Optional: override “Open EaveMeasure” link in roof reports (defaults to eavemeasure.com aerial services page).
# EXPO_PUBLIC_EAVEMEASURE_URL=https://eavemeasure.com/aerial-roof-measurement-services/

# ========================================
# BACKEND ENVIRONMENT (Cloudflare Workers)
# ========================================
SESSION_SECRET=your-super-secret-key-change-this
OPENAI_API_KEY=sk-your-openai-api-key
CLOUDFLARE_ACCOUNT_ID=your-account-id
CLOUDFLARE_API_TOKEN=your-api-token

# ========================================
# DATABASE CONFIGURATION
# ========================================
D1_DATABASE_ID=your-d1-database-id
WRANGLER_KV_NAMESPACE_ID=your-kv-namespace-id

# ========================================
# SUPABASE (optional direct client usage)
# ========================================
# If set, the app can store uploaded CSV leads into Supabase.
EXPO_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
EXPO_PUBLIC_SUPABASE_LEADS_TABLE=roof_leads

# ========================================
# DEPLOYMENT CONFIGURATION
# ========================================
DEPLOYMENT_MODE=local  # local, docker, cloudflare
APP_DOMAIN=hardcoredoortodoorclosers.com
CUSTOM_DOMAIN=hardcoredoortodoorclosers.com
CLOUDFLARE_ZONE_ID=your-zone-id

# ========================================
# OPTIONAL INTEGRATIONS
# ========================================
STRIPE_SECRET_KEY=sk_test_your-key
SIMPLETALK_API_KEY=your-simpletalk-key
TWILIO_ACCOUNT_SID=your-account-sid
TWILIO_AUTH_TOKEN=your-auth-token

# ========================================
# FEATURE FLAGS
# ========================================
ENABLE_2FA=true
ENABLE_AI_FEATURES=true
ENABLE_SOCIAL_NETWORK=true
ENABLE_VENDOR_MARKETPLACE=true
ENABLE_ANALYTICS=true
