# HD2D Platform - Environment Variables Template

# ========================================
# FRONTEND ENVIRONMENT (Expo/Web)
# ========================================
EXPO_PUBLIC_API_URL=http://localhost:8787
EXPO_PUBLIC_DOMAIN=localhost
EXPO_PUBLIC_ENVIRONMENT=development
EXPO_PUBLIC_MAPBOX_TOKEN=your-mapbox-token

# Client-side AI defaults (EXPO_PUBLIC_* is embedded in the app bundle — avoid real secrets in production; prefer Worker + OPENAI_API_KEY).
EXPO_PUBLIC_OPENAI_API_KEY=sk-your-api-key-here
EXPO_PUBLIC_MODEL=gpt-4
EXPO_PUBLIC_TEMPERATURE=0.7
EXPO_PUBLIC_MAX_TOKENS=2000

# Damage report “AI roof pitch gauge” calls POST /api/ai/roof-pitch on your Worker.
# Set OPENAI_API_KEY as a Wrangler secret on the backend (not in EXPO_PUBLIC_*).

# Optional: override “Open EaveMeasure” link in roof reports (defaults to eavemeasure.com aerial services page).
# EXPO_PUBLIC_EAVEMEASURE_URL=https://eavemeasure.com/aerial-roof-measurement-services/

# ========================================
# BACKEND ENVIRONMENT (Cloudflare Workers)
# ========================================
SESSION_SECRET=your-super-secret-key-change-this
OPENAI_API_KEY=sk-your-openai-api-key
CLOUDFLARE_ACCOUNT_ID=your-account-id
CLOUDFLARE_API_TOKEN=your-api-token

# Optional: Python roof vision service (backend/ml-vision-service). Worker proxies POST /api/ai/roof-vision.
# wrangler secret put ROOF_VISION_SERVICE_URL
# wrangler secret put ROOF_VISION_SERVICE_SECRET
# ROOF_VISION_SERVICE_URL=https://your-vision-service.example.com
# ROOF_VISION_SERVICE_SECRET=match-SERVICE_SECRET-in-Python-.env

# ========================================
# DATABASE CONFIGURATION
# ========================================
D1_DATABASE_ID=your-d1-database-id
WRANGLER_KV_NAMESPACE_ID=your-kv-namespace-id

# ========================================
# SUPABASE
# ========================================
# Personal access token (sbp_…) — CLI, CI, Management API only. Never EXPO_PUBLIC_* or client bundle.
# SUPABASE_ACCESS_TOKEN=
#
# App client: Dashboard → your project → Settings → API (Project URL + anon public key — long JWT, not sbp_).
EXPO_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
EXPO_PUBLIC_SUPABASE_LEADS_TABLE=roof_leads

# ========================================
# DEPLOYMENT CONFIGURATION
# ========================================
DEPLOYMENT_MODE=local  # local, docker, cloudflare
APP_DOMAIN=hardcoredoortodoorclosers.com
CUSTOM_DOMAIN=hardcoredoortodoorclosers.com
CLOUDFLARE_ZONE_ID=your-zone-id

# ========================================
# OPTIONAL INTEGRATIONS
# ========================================
STRIPE_SECRET_KEY=sk_test_your-key
SIMPLETALK_API_KEY=your-simpletalk-key
TWILIO_ACCOUNT_SID=your-account-sid
TWILIO_AUTH_TOKEN=your-auth-token

# ========================================
# PRECISION MEASUREMENT (Expo)
# ========================================
# When true, the app boots straight into Precision measurement (demo address below).
# Normal app (auth, tabs): leave unset or false.
# EXPO_PUBLIC_BOOTSTRAP_PRECISION_MEASUREMENT=false

# Prefer server proxy for production; optional client-side providers need:
# EXPO_PUBLIC_ALLOW_CLIENT_MEASUREMENT=true
# EXPO_PUBLIC_NEARMAP_API_KEY=
# EagleView: use access token OR client id + secret (not EXPO_PUBLIC_EAGLEVIEW_API_KEY).
# EXPO_PUBLIC_EAGLEVIEW_ACCESS_TOKEN=
# EXPO_PUBLIC_EAGLEVIEW_CLIENT_ID=
# EXPO_PUBLIC_EAGLEVIEW_CLIENT_SECRET=

# ========================================
# FEATURE FLAGS
# ========================================
ENABLE_2FA=true
ENABLE_AI_FEATURES=true
ENABLE_SOCIAL_NETWORK=true
ENABLE_VENDOR_MARKETPLACE=true
ENABLE_ANALYTICS=true
